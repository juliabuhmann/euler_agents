#!/usr/bin/env bash
# Host-side launcher: resolves config, sets up workspace and tmpdir, fires Singularity.
# Called by slurm/run-agent.sh (inside a SLURM job) or directly for interactive use.
#
# Usage: euler-agent-run [--agent codex|claude] [--task "prompt"] [--task-file FILE]
#                        [--repo URL] [--model MODEL] [--project NAME] [--interactive]
#                        [--max-budget-usd N] [--effort low|medium|high|xhigh|max]
set -euo pipefail

usage() {
    cat <<'EOF'
euler-agent-run — set up workspace and launch an agent inside the Singularity container

USAGE
  euler-agent-run [OPTIONS]

Called automatically by SLURM via slurm/run-agent.sh. You can also invoke it
directly on a compute node (e.g. after euler-agent-submit --interactive).

OPTIONS
  --agent  codex|claude       Agent to run (default: codex)
  --task   "PROMPT"           Task description
  --task-file FILE            Read task from a file instead of --task
  --repo   URL                Git repo to clone into /workspace before running
  --model  MODEL              Model override (e.g. claude-sonnet-4-6, gpt-5.4)
  --project NAME              Named workspace; persists and is reused across jobs.
                              Without --project, a fresh timestamped dir is created.
  --max-budget-usd N          Hard USD spending cap (Claude only)
  --effort low|medium|high|xhigh|max
                              Thinking depth (Claude only)
  --auth   apikey|subscription
                              Claude auth source (default: apikey). 'apikey' uses
                              ANTHROPIC_API_KEY (pay-per-use, accurate cost reporting).
                              'subscription' injects CLAUDE_CODE_OAUTH_TOKEN, a long-lived
                              token from 'claude setup-token' (notional cost, plan rate limits
                              apply). Ignored for Codex.
  --ref DIR                   Bind a reference directory to /reference inside the container
  --github-auth               Inject GitHub credentials into the container so the agent can
                              clone private repos, commit, push, and open PRs. Requires
                              GITHUB_TOKEN, GIT_USER_NAME, GIT_USER_EMAIL in
                              config/secrets.local.env. Off by default.
  --interactive               Open an interactive shell inside the container instead of running
  --claude-login              One-time: run 'claude auth login' with home-claude/ writable to
                              obtain the full-scope OAuth login Remote Control requires. Run this
                              directly on a login node (needs a TTY + internet); no SLURM.
  --remote-control            Start a steerable Claude session (drive it from claude.ai/code or the
                              mobile app) instead of running a task headless. Claude-only; requires
                              --project (transcripts persist in the project home). Model is chosen
                              per-session in the app; --model/--effort/--max-budget-usd/--auth
                              do not apply (it runs on the stored OAuth login).
  -h, --help                  Show this help

Task resolution order (highest priority first):
  1. --task flag
  2. --task-file flag
  3. config/task.json (also pulls model, effort, budget, repo_url, project from there)
  4. Agent defaults in config/settings.json

EXAMPLES
  # Run claude on a task (on a compute node or in an existing SLURM job)
  euler-agent-run --agent claude --task "Write unit tests for src/utils.py" \
      --project myproject --max-budget-usd 5

  # Interactive shell inside the Singularity container
  euler-agent-run --agent codex --project myproject --interactive

  # Provide a reference dataset inside the container
  euler-agent-run --agent claude --project myproject \
      --ref /cluster/project/beltrao/shared/data \
      --task "Analyse the CSV files in /reference and write a summary."

CONFIGURATION
  config/settings.json   Image path, workspace dir, per-agent model/budget defaults
  config/task.json       Default task used when no --task / --task-file given
  config/secrets.env     API keys (gitignored, sourced automatically)
EOF
}

SCRIPT_PATH=$(realpath "$0")
REPO_DIR=$(dirname "$(dirname "$SCRIPT_PATH")")
SETTINGS="$REPO_DIR/config/settings.json"

SETTINGS_LOCAL="$REPO_DIR/config/settings.local.json"
if [[ -f "$SETTINGS_LOCAL" ]]; then
    _TMP=$(mktemp)
    python3 -c "
import json
s = json.load(open('$SETTINGS'))
s.update(json.load(open('$SETTINGS_LOCAL')))
json.dump(s, open('$_TMP', 'w'))
"
    SETTINGS="$_TMP"
fi

_setting() {
    python3 -c "import json; s=json.load(open('$SETTINGS')); print($1)"
}

WORKSPACE_DIR=$(_setting "s['workspace_dir']")
IMAGE_PATH=$(_setting "s['image_path']")
LOGS_DIR=$(_setting "s.get('logs_dir', s['workspace_dir'] + '/logs')")

# Parse args
AGENT="codex"
TASK=""
TASK_FILE=""
REPO_URL=""
MODEL=""
MAX_BUDGET_USD=""
AGENT_EFFORT=""
AUTH_MODE=""
PROJECT=""
REF_DIR=""
INTERACTIVE=false
GPU=false
GITHUB_AUTH=false
NOTIFY_SUCCESS_OVERRIDE=""
REMOTE_CONTROL=false
CLAUDE_LOGIN=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)           usage; exit 0 ;;
        --agent)             AGENT="$2";               shift 2 ;;
        --task)              TASK="$2";                shift 2 ;;
        --task-file)         TASK_FILE="$2";           shift 2 ;;
        --repo)              REPO_URL="$2";            shift 2 ;;
        --model)             MODEL="$2";               shift 2 ;;
        --max-budget-usd)    MAX_BUDGET_USD="$2";      shift 2 ;;
        --effort)            AGENT_EFFORT="$2";        shift 2 ;;
        --auth)              AUTH_MODE="$2";           shift 2 ;;
        --project)           PROJECT="$2";             shift 2 ;;
        --ref)               REF_DIR="$2";             shift 2 ;;
        --github-auth)       GITHUB_AUTH=true;         shift ;;
        --remote-control)    REMOTE_CONTROL=true;      shift ;;
        --claude-login)      CLAUDE_LOGIN=true;        shift ;;
        --gpu)               GPU=true;                 shift ;;
        --gpu-type)          shift 2 ;;  # consumed by euler-agent-submit, ignored here
        --interactive)       INTERACTIVE=true;         shift ;;
        --notify-success)    NOTIFY_SUCCESS_OVERRIDE="true";  shift ;;
        --no-notify-success) NOTIFY_SUCCESS_OVERRIDE="false"; shift ;;
        *) echo "Unknown argument: $1" >&2; echo "Run with --help for usage." >&2; exit 1 ;;
    esac
done

# One-time interactive OAuth login for Claude Remote Control.
# Remote Control requires a full-scope claude.ai login token (API keys and the
# inference-only `claude setup-token` are both rejected). We run `claude auth login`
# with home-claude/ bound WRITABLE so the resulting credentials persist there and
# later seed each project's persistent Remote Control home.
# Run this directly on a login node (has internet); it needs a TTY for the browser flow.
if [[ "$CLAUDE_LOGIN" == true ]]; then
    SOURCE_HOME="$REPO_DIR/home-claude"
    mkdir -p "$SOURCE_HOME"
    echo "Launching 'claude auth login' inside the container."
    echo "  Credentials persist in: $SOURCE_HOME  (gitignored)"
    echo "  Choose your claude.ai account (NOT an API key) when prompted."
    singularity exec \
        --cleanenv --containall \
        --home "$SOURCE_HOME:/home" \
        --env "PATH=/opt/conda/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin" \
        "$IMAGE_PATH" \
        bash -lc 'export HOME=/home; cd /home; claude auth login && echo && claude auth status'
    echo "If login succeeded, launch a steerable session with:"
    echo "  euler-agent-submit --agent claude --remote-control --project NAME --time 8:00:00"
    exit 0
fi

# Helper: read a field from settings.json scoped to the current agent.
# Each agent only reads its own section — codex and claude never share defaults.
_agent_setting() {
    python3 -c "
import json, sys
s = json.load(open('${SETTINGS}'))
val = s.get('${AGENT}', {}).get(sys.argv[1])
print('' if val is None else val)
" "$1"
}

# Resolve task: --task > --task-file > config/task.json.
# When reading task.json, also pull per-task overrides for model/effort/budget
# (CLI flags above take highest priority and are already set).
if [[ -n "$TASK" ]]; then
    : # already set by --task flag
elif [[ -n "$TASK_FILE" ]]; then
    TASK=$(cat "$TASK_FILE")
else
    _tj() {
        python3 -c "
import json, sys
t = json.load(open('${REPO_DIR}/config/task.json'))
val = t.get(sys.argv[1])
print('' if val is None else val)
" "$1"
    }
    TASK=$(_tj task)
    [[ -z "$REPO_URL"       ]] && REPO_URL=$(_tj repo_url)
    [[ -z "$PROJECT"        ]] && PROJECT=$(_tj project)
    [[ -z "$MODEL"          ]] && MODEL=$(_tj model)
    [[ -z "$MAX_BUDGET_USD" ]] && MAX_BUDGET_USD=$(_tj max_budget_usd)
    [[ -z "$AGENT_EFFORT"   ]] && AGENT_EFFORT=$(_tj effort)
fi

# Fill any remaining blanks from agent-specific settings.json defaults.
[[ -z "$MODEL"          ]] && MODEL=$(_agent_setting model)
[[ -z "$MAX_BUDGET_USD" ]] && MAX_BUDGET_USD=$(_agent_setting max_budget_usd)
[[ -z "$AGENT_EFFORT"   ]] && AGENT_EFFORT=$(_agent_setting effort)
[[ -z "$AUTH_MODE"      ]] && AUTH_MODE=$(_agent_setting auth)
[[ -z "$AUTH_MODE"      ]] && AUTH_MODE="apikey"

# Remote Control mode: a long-running, steerable Claude session (claude.ai/mobile app).
# Distinct from the headless one-shot path — requires a persistent, project-scoped home
# so the conversation transcripts survive the job (stored under .claude-home).
if [[ "$REMOTE_CONTROL" == true ]]; then
    [[ "$AGENT" == claude ]] || { echo "ERROR: --remote-control is claude-only." >&2; exit 1; }
    [[ -n "$PROJECT"      ]] || { echo "ERROR: --remote-control requires --project (session transcript persists in the project home)." >&2; exit 1; }
fi

# Load API credentials (secrets.env is the template; secrets.local.env holds real values)
SECRETS="$REPO_DIR/config/secrets.env"
[[ -f "$SECRETS" ]] && source "$SECRETS"
SECRETS_LOCAL="$REPO_DIR/config/secrets.local.env"
[[ -f "$SECRETS_LOCAL" ]] && source "$SECRETS_LOCAL"
OPENAI_API_KEY="${OPENAI_API_KEY:-}"
ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:-}"
CLAUDE_CODE_OAUTH_TOKEN="${CLAUDE_CODE_OAUTH_TOKEN:-}"
GITHUB_TOKEN="${GITHUB_TOKEN:-}"
GIT_USER_NAME="${GIT_USER_NAME:-}"
GIT_USER_EMAIL="${GIT_USER_EMAIL:-}"

# Resolve workspace: named project (persistent, reused) or timestamped (one-off)
if [[ -n "$PROJECT" ]]; then
    RUN_WORKSPACE="$WORKSPACE_DIR/$PROJECT"
else
    RUN_WORKSPACE="$WORKSPACE_DIR/${AGENT}_$(date +%Y%m%d_%H%M%S)_${SLURM_JOB_ID:-interactive}"
fi
mkdir -p "$RUN_WORKSPACE"

# Set up job-scoped tmpdir (scratch + conda caches)
JOB_TMPDIR="${TMPDIR:-/tmp}/euler-agents.${SLURM_JOB_ID:-$$}"
mkdir -p "$JOB_TMPDIR/scratch" "$JOB_TMPDIR/conda_pkgs"

# Write task to job-specific scratch (not workspace) to avoid races on parallel jobs
printf '%s' "$TASK" > "$JOB_TMPDIR/scratch/.task"

# Give each job its own home copy so parallel jobs don't race on agent cache/state.
# Remote Control is the exception: it uses a persistent, project-scoped home so the
# OAuth token refreshes and the conversation transcript survive across jobs.
SOURCE_HOME="$REPO_DIR/home-${AGENT}"
mkdir -p "$SOURCE_HOME"
if [[ "$REMOTE_CONTROL" == true ]]; then
    JOB_HOME="$RUN_WORKSPACE/.claude-home"
    if [[ ! -d "$JOB_HOME" ]]; then
        echo "Seeding persistent Claude home at $JOB_HOME from $SOURCE_HOME"
        cp -r "$SOURCE_HOME" "$JOB_HOME"
    else
        echo "Reusing persistent Claude home at $JOB_HOME (session transcripts live here)"
    fi
else
    JOB_HOME="$JOB_TMPDIR/home-${AGENT}"
    cp -r "$SOURCE_HOME" "$JOB_HOME"
fi

echo "Workspace: $RUN_WORKSPACE"
echo "Agent:     $AGENT"
echo "Image:     $IMAGE_PATH"

# Build --env args for singularity
SING_ENV=(
    --env "AGENT=$AGENT"
    --env "REPO_URL=${REPO_URL:-}"
    --env "AGENT_MODEL=${MODEL:-}"
    --env "AGENT_MAX_BUDGET_USD=${MAX_BUDGET_USD:-}"
    --env "AGENT_EFFORT=${AGENT_EFFORT:-}"
    --env "CONDA_ENVS_DIRS=/workspace/conda_envs:/opt/conda/envs"
    --env "CONDA_PKGS_DIRS=/tmp/conda_pkgs"
)
[[ -n "$OPENAI_API_KEY" ]]   && SING_ENV+=(--env "OPENAI_API_KEY=$OPENAI_API_KEY")

# Anthropic auth (Claude only). Two modes; each withholds the other's credential
# (--containall --cleanenv keeps any host credential out, so not injecting is enough):
#   subscription — inject CLAUDE_CODE_OAUTH_TOKEN, a long-lived `claude setup-token`.
#                  Cost reporting is notional; bound by plan rate limits.
#   apikey       — inject ANTHROPIC_API_KEY (pay-per-use, accurate cost reporting).
if [[ "$REMOTE_CONTROL" == true ]]; then
    # Inject no credential: Remote Control uses the full-scope OAuth login stored in
    # the persistent home (from `euler-agent-run --claude-login`). An injected
    # ANTHROPIC_API_KEY or inference-only token would be rejected by Remote Control.
    if [[ ! -f "$JOB_HOME/.claude/.credentials.json" ]]; then
        echo "WARNING: no OAuth credentials found in $JOB_HOME/.claude/.credentials.json." >&2
        echo "         Remote Control will fail to start. Run 'euler-agent-run --claude-login' first," >&2
        echo "         then delete $JOB_HOME so it re-seeds from the fresh login." >&2
    fi
    echo "Auth:      Claude subscription (full-scope OAuth from persistent home)"
elif [[ "$AGENT" == claude && "$AUTH_MODE" == subscription ]]; then
    if [[ -z "$CLAUDE_CODE_OAUTH_TOKEN" ]]; then
        echo "ERROR: --auth subscription requires CLAUDE_CODE_OAUTH_TOKEN in config/secrets.local.env." >&2
        echo "       Generate one with 'claude setup-token'. Use --auth apikey for pay-per-use instead." >&2
        exit 1
    fi
    SING_ENV+=(--env "CLAUDE_CODE_OAUTH_TOKEN=$CLAUDE_CODE_OAUTH_TOKEN")
    echo "Auth:      Claude subscription (long-lived OAuth token)"
elif [[ "$AGENT" == claude && -z "$ANTHROPIC_API_KEY" ]]; then
    echo "ERROR: --auth apikey requires ANTHROPIC_API_KEY in config/secrets.local.env." >&2
    echo "       Use --auth subscription to run on your Claude subscription instead." >&2
    exit 1
else
    [[ -n "$ANTHROPIC_API_KEY" ]] && SING_ENV+=(--env "ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY")
    [[ "$AGENT" == claude ]] && echo "Auth:      Anthropic API key"
fi
[[ -n "${SLURM_JOB_ID:-}" ]] && SING_ENV+=(--env "SLURM_JOB_ID=$SLURM_JOB_ID")
if [[ "$REMOTE_CONTROL" == true ]]; then
    SING_ENV+=(
        --env "REMOTE_CONTROL=true"
        --env "RC_SESSION_NAME=euler-rc-${PROJECT}-${SLURM_JOB_ID:-interactive}"
    )
fi
if [[ "$GITHUB_AUTH" == true ]]; then
    [[ -z "$GITHUB_TOKEN" ]] && { echo "ERROR: --github-auth requires GITHUB_TOKEN in secrets.local.env" >&2; exit 1; }
    SING_ENV+=(
        --env "GIT_AUTH=true"
        --env "GITHUB_TOKEN=$GITHUB_TOKEN"
        --env "GIT_USER_NAME=${GIT_USER_NAME:-euler-agent}"
        --env "GIT_USER_EMAIL=${GIT_USER_EMAIL:-euler-agent@localhost}"
    )
fi

SING_BINDS=(
    --home "$JOB_HOME:/home"
    --bind "$RUN_WORKSPACE:/workspace"
    --bind "$REPO_DIR:/repo:ro"
    --bind "$JOB_TMPDIR/scratch:/tmp"
)
[[ -n "$REF_DIR" ]] && SING_BINDS+=(--bind "$REF_DIR:/reference:ro")

NV_FLAG=()
[[ "$GPU" == true ]] && NV_FLAG=(--nv)

if [[ "$INTERACTIVE" == true ]]; then
    echo "Opening interactive shell inside container..."
    echo "  Workspace: /workspace  (persists at $RUN_WORKSPACE)"
    [[ "$GPU" == true ]] && echo "  GPU mode enabled (--nv)"
    singularity shell \
        --cleanenv --containall \
        "${NV_FLAG[@]+"${NV_FLAG[@]}"}" \
        "${SING_ENV[@]}" \
        "${SING_BINDS[@]}" \
        "$IMAGE_PATH"
else
    AGENT_EXIT=0
    singularity exec \
        --cleanenv --containall \
        "${NV_FLAG[@]+"${NV_FLAG[@]}"}" \
        "${SING_ENV[@]}" \
        "${SING_BINDS[@]}" \
        "$IMAGE_PATH" \
        /repo/bin/inner.sh || AGENT_EXIT=$?

    NOTIFY_EMAIL_ENABLED=$(_setting "str(s.get('notifications', {}).get('email', {}).get('enabled', False)).lower()")
    NOTIFY_EMAIL_ADDRESS=$(_setting "s.get('notifications', {}).get('email', {}).get('address', '')")
    NOTIFY_ON_FAILURE=$(_setting "str(s.get('notifications', {}).get('email', {}).get('on_failure', True)).lower()")
    NOTIFY_ON_SUCCESS_CFG=$(_setting "str(s.get('notifications', {}).get('email', {}).get('on_success', False)).lower()")
    NOTIFY_ON_SUCCESS="${NOTIFY_SUCCESS_OVERRIDE:-$NOTIFY_ON_SUCCESS_CFG}"

    NOTIFY_EMAIL_ENABLED="$NOTIFY_EMAIL_ENABLED" \
    NOTIFY_EMAIL_ADDRESS="$NOTIFY_EMAIL_ADDRESS" \
    NOTIFY_ON_FAILURE="$NOTIFY_ON_FAILURE" \
    NOTIFY_ON_SUCCESS="$NOTIFY_ON_SUCCESS" \
    LOGS_DIR="$LOGS_DIR" \
    "$REPO_DIR/bin/notify.sh" \
        --exit-code "$AGENT_EXIT" \
        --workspace "$RUN_WORKSPACE" \
        --agent "$AGENT" || true

    exit "$AGENT_EXIT"
fi
