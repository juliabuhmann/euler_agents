#!/usr/bin/env bash
# User-facing entry point for submitting agent jobs.
#
# Usage:
#   euler-agent-submit [--agent codex|claude] [--task "prompt"] [--task-file FILE]
#                      [--repo URL] [--model MODEL] [--time HH:MM:SS] [--interactive]
#
# Without --task / --task-file, reads task from config/task.json.
# --interactive opens a shell on a compute node (srun) instead of submitting via sbatch.
set -euo pipefail

usage() {
    cat <<'EOF'
euler-agent-submit — submit an AI coding agent job to Euler's SLURM cluster

USAGE
  euler-agent-submit [OPTIONS]

OPTIONS
  --agent  codex|claude   Agent to run (default: codex)
  --task   "PROMPT"       Task description passed to the agent
  --task-file FILE        Read task from a file instead of --task
  --repo   URL            Git repo to clone into the workspace before running
  --model  MODEL          Override the model (e.g. claude-sonnet-4-6, gpt-5.4)
  --time   HH:MM:SS       SLURM wall-clock limit (default from config/settings.json)
  --interactive           Open a shell on a compute node via srun instead of sbatch
  --notify-success        Send a notification email on success (overrides config)
  --no-notify-success     Suppress success notification for this run (overrides config)
  -h, --help              Show this help

Without --task / --task-file, reads the task from config/task.json.
Additional flags (--project, --max-budget-usd, --effort, --ref) are forwarded
to euler-agent-run; see: euler-agent-run --help

EXAMPLES
  # One-off task
  euler-agent-submit --agent codex --task "Add type annotations to src/"

  # Named project (workspace persists across jobs)
  euler-agent-submit --agent claude --project myanalysis \
      --task "Explore the dataset and write a summary"

  # Read task from a file
  euler-agent-submit --agent claude --task-file tasks/myanalysis.md

  # Interactive shell on a compute node
  euler-agent-submit --interactive --agent codex --project myanalysis

  # Longer time limit
  euler-agent-submit --agent claude --task "..." --time 8:00:00

CONFIGURATION
  config/settings.json   SLURM defaults (time, mem, cpus), workspace/logs paths
  config/task.json       Default task, model, and budget (used when no --task flag)
  config/secrets.env     API keys (gitignored, sourced automatically)
EOF
}

SCRIPT_PATH=$(realpath "$0")
REPO_DIR=$(dirname "$(dirname "$SCRIPT_PATH")")
SETTINGS="$REPO_DIR/config/settings.json"

SETTINGS_LOCAL="$REPO_DIR/config/settings.local.json"
if [[ -f "$SETTINGS_LOCAL" ]]; then
    _TMP=$(mktemp)
    python3 -c "
import json
s = json.load(open('$SETTINGS'))
s.update(json.load(open('$SETTINGS_LOCAL')))
json.dump(s, open('$_TMP', 'w'))
"
    SETTINGS="$_TMP"
fi

_setting() {
    python3 -c "import json; s=json.load(open('$SETTINGS')); print($1)"
}

LOGS_DIR=$(_setting "s.get('logs_dir', s['workspace_dir'] + '/logs')")
SLURM_TIME=$(_setting "s.get('slurm', {}).get('time', '4:00:00')")
SLURM_MEM=$(_setting "s.get('slurm', {}).get('mem_per_cpu', '8G')")
SLURM_CPUS=$(_setting "s.get('slurm', {}).get('cpus', 2)")

INTERACTIVE=false
OVERRIDE_TIME=""
PASSTHROUGH=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help) usage; exit 0 ;;
        --interactive) INTERACTIVE=true; shift ;;
        --time) OVERRIDE_TIME="$2"; shift 2 ;;
        *) PASSTHROUGH+=("$1"); shift ;;
    esac
done

[[ -n "$OVERRIDE_TIME" ]] && SLURM_TIME="$OVERRIDE_TIME"

mkdir -p "$LOGS_DIR"

if [[ "$INTERACTIVE" == true ]]; then
    echo "Starting interactive session on a compute node..."
    echo "Agent launcher available at: $REPO_DIR/bin/euler-agent-run"
    srun \
        --time="$SLURM_TIME" \
        --mem-per-cpu="$SLURM_MEM" \
        --cpus-per-task="$SLURM_CPUS" \
        --pty \
        "$REPO_DIR/bin/euler-agent-run" --interactive "${PASSTHROUGH[@]+"${PASSTHROUGH[@]}"}"
else
    echo "Submitting SLURM job..."
    sbatch \
        --export=ALL,EULER_AGENTS_DIR="$REPO_DIR" \
        --output="$LOGS_DIR/slurm-%j.out" \
        --error="$LOGS_DIR/slurm-%j.err" \
        "$REPO_DIR/slurm/run-agent.sh" \
        "${PASSTHROUGH[@]+"${PASSTHROUGH[@]}"}"
fi
