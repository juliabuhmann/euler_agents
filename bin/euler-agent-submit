#!/usr/bin/env bash
# User-facing entry point for submitting agent jobs.
#
# Usage:
#   euler-agent-submit [--agent codex|claude] [--task "prompt"] [--task-file FILE]
#                      [--repo URL] [--model MODEL] [--time HH:MM:SS] [--interactive]
#                      [--gpu] [--gpu-type TYPE] [--partition NAME]
#
# Without --task / --task-file, reads task from config/task.json.
# --interactive opens a shell on a compute node (srun) instead of submitting via sbatch.
set -euo pipefail

usage() {
    cat <<'EOF'
euler-agent-submit — submit an AI coding agent job to Euler's SLURM cluster

USAGE
  euler-agent-submit [OPTIONS]

OPTIONS
  --agent  codex|claude   Agent to run (default: codex)
  --task   "PROMPT"       Task description passed to the agent
  --task-file FILE        Read task from a file instead of --task
  --repo   URL            Git repo to clone into the workspace before running
  --model  MODEL          Override the model (e.g. claude-sonnet-4-6, gpt-5.4)
  --time   HH:MM:SS       SLURM wall-clock limit (default from config/settings.json)
  --interactive           Open a shell on a compute node via srun instead of sbatch
  --notify-success        Send a notification email on success (overrides config)
  --no-notify-success     Suppress success notification for this run (overrides config)
  --gpu                   Request a GPU node (adds --gpus, --tmp=50G, sets GPU partition)
  --gpu-type TYPE         GPU type to request (default: a100). Known types on Euler:
                            a100                    — any A100 (40 or 80 GB)
                            nvidia_a100_80gb_pcie   — A100 80 GB (use with --gpu-mem 80g)
                            nvidia_rtx_pro_6000     — RTX Pro 6000 Blackwell 96 GB
                            nvidia_geforce_rtx_4090 — RTX 4090 24 GB
                            nvidia_geforce_rtx_3090 — RTX 3090 24 GB
  --preset NAME           Apply a resource preset from config/presets.json.
                            Built-in: lightweight (1 CPU, 2G), medium-cpu (4 CPU, 32G),
                            medium-gpu (4 CPU, 32G, A100 40GB). Individual flags override preset.
  --cpus N                Number of CPUs (default from settings).
  --mem-per-cpu SIZE      RAM per CPU, e.g. 4G or 8G (default from settings).
                            Total RAM = N × SIZE. e.g. --cpus 6 --mem-per-cpu 8G gives 48 GB.
  --gpu-mem SIZE          GPU memory filter, e.g. 80g or 96g. Adds --gres=gpumem:SIZE
                            to the sbatch call so the scheduler picks a node with at
                            least that much GPU VRAM. Use this to distinguish 40 GB vs
                            80 GB A100s, or to target RTX Pro 6000 (96g). On Euler,
                            --gpu-type alone does not enforce memory — this flag does.
  --partition NAME        Override the SLURM partition (default: auto-selected from --time:
                            ≤4h → gpupr.4h, ≤24h → gpupr.24h, else → gpupr.120h)
  --github-auth           Inject GitHub credentials into the container (requires GITHUB_TOKEN,
                            GIT_USER_NAME, GIT_USER_EMAIL in config/secrets.local.env).
                            Off by default — enable only when the agent needs to clone private
                            repos, commit, push, or open PRs.
  -h, --help              Show this help

Without --task / --task-file, reads the task from config/task.json.
Additional flags (--project, --max-budget-usd, --effort, --auth, --ref,
--remote-control) are forwarded to euler-agent-run; see: euler-agent-run --help
  --auth apikey|subscription   Claude auth: API key (default) or subscription (CLAUDE_CODE_OAUTH_TOKEN).
  --remote-control             Start a steerable Claude session driven from claude.ai/mobile app.
                               Claude-only; requires --project. First run 'euler-agent-run --claude-login'.

EXAMPLES
  # One-off task
  euler-agent-submit --agent codex --task "Add type annotations to src/"

  # Named project (workspace persists across jobs)
  euler-agent-submit --agent claude --project myanalysis \
      --task "Explore the dataset and write a summary"

  # Read task from a file
  euler-agent-submit --agent claude --task-file tasks/myanalysis.md

  # Interactive shell on a compute node
  euler-agent-submit --interactive --agent codex --project myanalysis

  # Longer time limit
  euler-agent-submit --agent claude --task "..." --time 8:00:00

CONFIGURATION
  config/settings.json   SLURM defaults (time, mem, cpus), workspace/logs paths
  config/task.json       Default task, model, and budget (used when no --task flag)
  config/secrets.env     API keys (gitignored, sourced automatically)
EOF
}

SCRIPT_PATH=$(realpath "$0")
REPO_DIR=$(dirname "$(dirname "$SCRIPT_PATH")")
SETTINGS="$REPO_DIR/config/settings.json"

SETTINGS_LOCAL="$REPO_DIR/config/settings.local.json"
if [[ -f "$SETTINGS_LOCAL" ]]; then
    _TMP=$(mktemp)
    python3 -c "
import json
s = json.load(open('$SETTINGS'))
s.update(json.load(open('$SETTINGS_LOCAL')))
json.dump(s, open('$_TMP', 'w'))
"
    SETTINGS="$_TMP"
fi

_setting() {
    python3 -c "import json; s=json.load(open('$SETTINGS')); print($1)"
}

LOGS_DIR=$(_setting "s.get('logs_dir', s['workspace_dir'] + '/logs')")
SLURM_TIME=$(_setting "s.get('slurm', {}).get('time', '4:00:00')")
SLURM_MEM=$(_setting "s.get('slurm', {}).get('mem_per_cpu', '8G')")
SLURM_CPUS=$(_setting "s.get('slurm', {}).get('cpus', 2)")

INTERACTIVE=false
GPU=false
GPU_TYPE="a100"
GPU_MEM=""
GPU_PARTITION_OVERRIDE=""
OVERRIDE_TIME=""
PASSTHROUGH=()

PRESETS_FILE="$REPO_DIR/config/presets.json"

_apply_preset() {
    local name="$1"
    local preset
    preset=$(python3 -c "
import json, sys
p = json.load(open('$PRESETS_FILE'))
if '$name' not in p:
    print('Unknown preset. Available: ' + ', '.join(p.keys()), file=sys.stderr)
    sys.exit(1)
v = p['$name']
print(v.get('cpus', ''))
print(v.get('mem_per_cpu', ''))
print(v.get('gpu', False))
print(v.get('gpu_type', 'a100'))
print(v.get('gpu_mem', ''))
") || exit 1
    local cpus mem_per_cpu gpu gpu_type gpu_mem
    IFS=$'\n' read -r cpus mem_per_cpu gpu gpu_type gpu_mem <<< "$preset"
    [[ -n "$cpus" ]]       && SLURM_CPUS="$cpus"
    [[ -n "$mem_per_cpu" ]] && SLURM_MEM="$mem_per_cpu"
    if [[ "$gpu" == "True" ]]; then
        GPU=true
        GPU_TYPE="$gpu_type"
        GPU_MEM="$gpu_mem"
        PASSTHROUGH+=(--gpu --gpu-type "$gpu_type")
    fi
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help) usage; exit 0 ;;
        --interactive) INTERACTIVE=true; shift ;;
        --preset) _apply_preset "$2"; shift 2 ;;
        --gpu) GPU=true; PASSTHROUGH+=("$1"); shift ;;
        --gpu-type) GPU_TYPE="$2"; PASSTHROUGH+=("$1" "$2"); shift 2 ;;
        --gpu-mem) GPU_MEM="$2"; shift 2 ;;
        --cpus) SLURM_CPUS="$2"; shift 2 ;;
        --mem-per-cpu) SLURM_MEM="$2"; shift 2 ;;
        --partition) GPU_PARTITION_OVERRIDE="$2"; shift 2 ;;
        --time) OVERRIDE_TIME="$2"; shift 2 ;;
        --github-auth) PASSTHROUGH+=("$1"); shift ;;
        --task-file)
            _tf="$2"
            if [[ ! -f "$_tf" ]]; then
                echo "ERROR: task file not found: $2" >&2
                exit 1
            fi
            PASSTHROUGH+=("$1" "$(realpath "$_tf")")
            shift 2 ;;
        *) PASSTHROUGH+=("$1"); shift ;;
    esac
done

[[ -n "$OVERRIDE_TIME" ]] && SLURM_TIME="$OVERRIDE_TIME"

# GPU jobs: pick gpupr partition based on requested time
_time_to_hours() {
    local time_str="$1"
    if [[ "$time_str" =~ ^([0-9]+)-([0-9]+):([0-9]+):([0-9]+)$ ]]; then
        echo $(( ${BASH_REMATCH[1]}*24 + ${BASH_REMATCH[2]} ))
    elif [[ "$time_str" =~ ^([0-9]+):([0-9]+):([0-9]+)$ ]]; then
        echo "${BASH_REMATCH[1]}"
    else
        echo 4
    fi
}

_gpu_partition() {
    local hours; hours=$(_time_to_hours "$1")
    if (( hours <= 4 )); then echo "gpupr.4h"
    elif (( hours <= 24 )); then echo "gpupr.24h"
    else echo "gpupr.120h"
    fi
}

# Known max hours per partition name (suffix-based for gpupr/gpu/gpuhe families)
_partition_max_hours() {
    case "$1" in
        *.4h)   echo 4   ;;
        *.24h)  echo 24  ;;
        *.120h) echo 120 ;;
        *.bulk) echo 360 ;;
        *)      echo ""  ;;  # unknown — skip check
    esac
}

if [[ "$GPU" == true ]]; then
    [[ -z "$OVERRIDE_TIME" ]] && SLURM_TIME="4:00:00"
    if [[ -n "$GPU_PARTITION_OVERRIDE" ]]; then
        GPU_PARTITION="$GPU_PARTITION_OVERRIDE"
        _max=$(_partition_max_hours "$GPU_PARTITION")
        if [[ -n "$_max" ]]; then
            _requested=$(_time_to_hours "$SLURM_TIME")
            if (( _requested > _max )); then
                echo "WARNING: requested time ${SLURM_TIME} (${_requested}h) exceeds the" \
                     "max for partition ${GPU_PARTITION} (${_max}h) — SLURM will likely reject this job." >&2
            fi
        fi
    else
        GPU_PARTITION=$(_gpu_partition "$SLURM_TIME")
    fi
    GPU_SLURM_ARGS=(--gpus=${GPU_TYPE}:1 -p ${GPU_PARTITION} --tmp=50G)
    # On Euler, --gpus=TYPE does not enforce the GPU type — the scheduler ignores the name
    # and assigns any available GPU. Use --gres=gpumem:SIZE to filter by VRAM instead.
    if [[ -n "$GPU_MEM" ]]; then
        GPU_SLURM_ARGS+=(--gres=gpumem:${GPU_MEM})
    fi
else
    GPU_SLURM_ARGS=()
    [[ -n "$GPU_PARTITION_OVERRIDE" ]] && GPU_SLURM_ARGS+=(-p "$GPU_PARTITION_OVERRIDE")
fi

mkdir -p "$LOGS_DIR"

if [[ "$INTERACTIVE" == true ]]; then
    echo "Starting interactive session on a compute node..."
    echo "Agent launcher available at: $REPO_DIR/bin/euler-agent-run"
    srun \
        --time="$SLURM_TIME" \
        --mem-per-cpu="$SLURM_MEM" \
        --cpus-per-task="$SLURM_CPUS" \
        "${GPU_SLURM_ARGS[@]+"${GPU_SLURM_ARGS[@]}"}" \
        --pty \
        "$REPO_DIR/bin/euler-agent-run" --interactive "${PASSTHROUGH[@]+"${PASSTHROUGH[@]}"}"
else
    SBATCH_CMD=(sbatch
        "${GPU_SLURM_ARGS[@]+"${GPU_SLURM_ARGS[@]}"}"
        --time="$SLURM_TIME"
        --mem-per-cpu="$SLURM_MEM"
        --cpus-per-task="$SLURM_CPUS"
        --export=ALL,EULER_AGENTS_DIR="$REPO_DIR"
        --output="$LOGS_DIR/slurm-%j.out"
        --error="$LOGS_DIR/slurm-%j.err"
        "$REPO_DIR/slurm/run-agent.sh"
        "${PASSTHROUGH[@]+"${PASSTHROUGH[@]}"}")
    echo "Submitting: ${SBATCH_CMD[*]}"
    "${SBATCH_CMD[@]}"
fi
